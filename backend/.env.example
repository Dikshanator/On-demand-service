# Backend Environment Configuration Template
# Copy this to backend/.env.local and fill in your values

# ===== DATABASE CONFIGURATION =====
# For local PostgreSQL:
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/hamrosewa"

# For Neon (cloud):
# DATABASE_URL="postgresql://user:password@ep-xyz.neon.tech/hamrosewa?sslmode=require"

# For Railway (cloud):
# DATABASE_URL="postgresql://postgres:password@containers-us-west-XXX.railway.app:5432/railway"

# ===== JWT & AUTHENTICATION =====
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-to-something-random"
JWT_EXPIRE="7d"
JWT_REFRESH_SECRET="your-refresh-secret-also-change-this"
JWT_REFRESH_EXPIRE="30d"

# ===== EMAIL CONFIGURATION =====
# Using Gmail:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
# Generate app password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD="your-16-character-app-password"
SMTP_FROM_EMAIL="noreply@hamrosewa.com"
SMTP_FROM_NAME="hamroSewa"

# Alternative: Using SendGrid
# SENDGRID_API_KEY="SG.your-api-key"

# Alternative: Using Mailgun
# MAILGUN_API_KEY="key-xxx"
# MAILGUN_DOMAIN="mg.example.com"

# ===== SERVER CONFIGURATION =====
PORT=5000
HOST="localhost"
NODE_ENV="development"  # development | staging | production

# ===== CORS SETTINGS =====
# Allow requests from these origins (comma-separated)
CORS_ORIGIN="http://localhost:3000,http://localhost:8081,http://localhost:19000,http://192.168.x.x:8081"

# ===== RATE LIMITING =====
# Time window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ===== FILE UPLOAD =====
# Max file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760
# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,application/pdf"

# ===== LOGGING =====
LOG_LEVEL="debug"  # error | warn | info | debug | trace
LOG_FORMAT="json"  # json | text

# ===== PAYMENT GATEWAY (Optional) =====
# Stripe
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Khalti (Nepali payment)
# KHALTI_PUBLIC_KEY="xxx"
# KHALTI_SECRET_KEY="xxx"

# ===== EXTERNAL SERVICES =====
# Google Maps API (for location services)
# GOOGLE_MAPS_API_KEY="xxx"

# Twilio (for SMS notifications)
# TWILIO_ACCOUNT_SID="xxx"
# TWILIO_AUTH_TOKEN="xxx"
# TWILIO_PHONE_NUMBER="+1234567890"

# ===== MONITORING & ANALYTICS (Optional) =====
# Sentry (error tracking)
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# SENTRY_ENVIRONMENT="development"

# ===== DATABASE BACKUP =====
# Backup schedule (cron format for production)
# DB_BACKUP_SCHEDULE="0 0 * * *"  # Daily at midnight
# BACKUP_RETENTION_DAYS=30
