# Frontend Environment Configuration Template
# Copy this to frontend/.env.development.local and fill in your values

# ===== API CONFIGURATION =====
# Local development
EXPO_PUBLIC_API_URL="http://localhost:5000/api"

# For Android emulator on Windows/Linux
# EXPO_PUBLIC_API_URL="http://10.0.2.2:5000/api"

# For real device (replace with your computer IP)
# EXPO_PUBLIC_API_URL="http://192.168.x.x:5000/api"

# API timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT="10000"

# ===== APP CONFIGURATION =====
EXPO_PUBLIC_APP_NAME="hamroSewa"
EXPO_PUBLIC_APP_VERSION="1.0.0"
EXPO_PUBLIC_BUILD_NUMBER="1"
EXPO_PUBLIC_ENVIRONMENT="development"  # development | staging | production

# ===== FEATURE FLAGS =====
# Enable/disable features for development
EXPO_PUBLIC_ENABLE_NOTIFICATIONS="true"
EXPO_PUBLIC_ENABLE_CHAT="true"
EXPO_PUBLIC_ENABLE_VOICE_CALL="true"
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS="false"
EXPO_PUBLIC_DEBUG_MODE="true"
EXPO_PUBLIC_VERBOSE_LOGGING="true"

# ===== FIREBASE CONFIGURATION (Optional - for push notifications) =====
# Get these from Firebase Console: https://console.firebase.google.com
EXPO_PUBLIC_FIREBASE_API_KEY=""
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=""
EXPO_PUBLIC_FIREBASE_PROJECT_ID=""
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=""
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
EXPO_PUBLIC_FIREBASE_APP_ID=""
EXPO_PUBLIC_FIREBASE_DATABASE_URL=""

# ===== SENTRY CONFIGURATION (Optional - error tracking) =====
EXPO_PUBLIC_SENTRY_DSN=""
EXPO_PUBLIC_SENTRY_ENVIRONMENT="development"
EXPO_PUBLIC_SENTRY_TRACE_SAMPLE_RATE="0.1"  # 10% of requests

# ===== GOOGLE MAPS (Optional - for location features) =====
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ===== ANALYTICS (Optional) =====
# Amplitude
# EXPO_PUBLIC_AMPLITUDE_API_KEY=""

# Mixpanel
# EXPO_PUBLIC_MIXPANEL_TOKEN=""

# ===== THEME & UI =====
# Default theme (light | dark | auto)
EXPO_PUBLIC_DEFAULT_THEME="auto"

# Brand color (hex format)
EXPO_PUBLIC_BRAND_COLOR="#208AEF"

# ===== NETWORK CONFIGURATION =====
# Request retry attempts
EXPO_PUBLIC_NETWORK_RETRY_ATTEMPTS="3"

# Request retry delay in milliseconds
EXPO_PUBLIC_NETWORK_RETRY_DELAY="1000"

# ===== STORAGE CONFIGURATION =====
# Enable local data caching
EXPO_PUBLIC_ENABLE_OFFLINE_MODE="true"

# Cache expiration time in hours
EXPO_PUBLIC_CACHE_EXPIRATION_HOURS="24"

# ===== SECURITY =====
# SSL/TLS certificate validation (false only for development with self-signed certs)
EXPO_PUBLIC_VERIFY_SSL="true"

# Enable HTTPS only (false for local development)
EXPO_PUBLIC_REQUIRE_HTTPS="false"
